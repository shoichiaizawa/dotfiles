function! s:FixHighlights(scheme) abort
  silent! highlight! link CursorLineSign CursorLine
  if a:scheme =~# '^solarized8' && exists('g:terminal_ansi_colors')
    " termtrans blanks gutter backgrounds to NONE; restore from palette.
    " g:terminal_ansi_colors is set by solarized8: [0]=base02, [5]=magenta
    let l:base02  = g:terminal_ansi_colors[0]
    let l:magenta = g:terminal_ansi_colors[5]
    execute 'silent! highlight SignColumn    guibg=' . l:base02 . ' ctermbg=0'
    execute 'silent! highlight FoldColumn   guibg=' . l:base02 . ' ctermbg=0'
    execute 'silent! highlight LineNr       guibg=' . l:base02 . ' ctermbg=0'
    execute 'silent! highlight Folded       guibg=' . l:base02 . ' ctermbg=0'
    execute 'silent! highlight CursorLineNr gui=bold guifg=#ffff00 guibg=' . l:base02 . ' cterm=bold ctermfg=226 ctermbg=0'
    execute 'silent! highlight Visual gui=NONE guifg=#e4e4e4 guibg=' . l:magenta . ' cterm=NONE ctermfg=254 ctermbg=125'
  else
    " Generic: sync FoldColumn to SignColumn — most themes set SignColumn
    " but forget FoldColumn, leaving it with Vim's default grey bg.
    silent! highlight! link FoldColumn SignColumn
  endif
  if exists('*gitgutter#highlight#define_highlights')
    call gitgutter#highlight#define_highlights()
  endif
endfunction

function! s:DeferFixHighlights(...) abort
  call s:FixHighlights(get(g:, 'colors_name', ''))
  redraw!
endfunction

call s:FixHighlights(get(g:, 'colors_name', ''))

augroup PersistColorscheme
  autocmd!
  autocmd VimEnter * call s:FixHighlights(get(g:, 'colors_name', ''))
  autocmd ColorScheme * call timer_start(0, function('s:DeferFixHighlights'))
  autocmd ColorScheme * call writefile([expand('<amatch>')], expand('~/.vim/.colorscheme'))
augroup END
