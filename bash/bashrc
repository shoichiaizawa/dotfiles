# ------------------------------------------------------------
# Visual Studio Code (https://github.com/microsoft/vscode)
# ------------------------------------------------------------

# Function to download and source VS Code completion scripts
setup_vscode_completion() {
  local appname="$1"
  local url="https://raw.githubusercontent.com/microsoft/vscode/main/resources/completions/bash/code"
  local completion_dir="$HOME/.local/share/bash-completion/completions"
  local completion_path="$completion_dir/$appname"

  mkdir -p "$completion_dir"

  # Re-download only if file is missing or older than 7 days
  if [ ! -f "$completion_path" ] || [ "$(find "$completion_path" -mtime +7 2>/dev/null)" ]; then
    if curl -sf -o "$completion_path.tmp" "$url" 2>/dev/null; then
      if [ "$(uname)" = "Darwin" ]; then
        sed -i '' "s/@@APPNAME@@/$appname/g" "$completion_path.tmp"
      else
        sed -i "s/@@APPNAME@@/$appname/g" "$completion_path.tmp"
      fi
      mv "$completion_path.tmp" "$completion_path"
    fi
  fi

  [ -f "$completion_path" ] && . "$completion_path"
}

# Setup completion for VS Code Stable
if command -v code >/dev/null 2>&1; then
  setup_vscode_completion "code"
fi

# Setup completion for VS Code Insiders
if command -v code-insiders >/dev/null 2>&1; then
  setup_vscode_completion "code-insiders"
  alias insiders="code-insiders"
  # Define completion for the 'insiders' alias
  if [ -n "$BASH_VERSION" ]; then
    complete -o default -o nospace -F _code-insiders insiders
  elif [ -n "$ZSH_VERSION" ]; then
    compdef _code-insiders insiders
  fi
fi

