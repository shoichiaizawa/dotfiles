# Function: rmh -- remove the most recent previous command from command history
#
# This helps the user to maintain his/her command history clean without invalid
# commands
#
# Usage: Enter a single space charater before the command
#        i.e. Run `$  rmh` instead of `$ rmh`
#
rmh() {
  tmp=$HISTTIMEFORMAT
  export HISTTIMEFORMAT=''
  local lastcmdhist=$(history 1)
  local lastcmdnum=$(echo "${lastcmdhist}" | awk '{print $1}')
  local lastcmd=$(echo "${lastcmdhist}" | cut -d ' ' -f3-)
  if [ -n "${lastcmdnum}" ]; then
    history -d "$lastcmdnum"
    echo "Removed the last command:${lastcmd}"
  fi
  export HISTTIMEFORMAT=$tmp
  unset tmp
}

# Function: open-chrome-tabs
# Usage: open-chrome-tabs [-n] <url1> <url2> ... <urlN>
# Or provide URLs via standard input, each on a new line. # Open URLs listed in a file
if [ -d "/Applications/Google Chrome.app" ]; then
  open-chrome-tabs() {
    # Initialize an array to hold URLs
    urls=()
    incognito=true

    # Parse options
    while getopts ":n" opt; do
      case ${opt} in
        n )
          incognito=false
          ;;
        \? )
          echo "Invalid option: -$OPTARG" >&2
          return 1
          ;;
      esac
    done
    shift $((OPTIND -1))

    # Check if input is coming from a pipe or here-document
    if [ ! -t 0 ]; then
      # Read URLs from standard input
      while IFS= read -r url; do
        # Skip empty lines
        [ -n "$url" ] && urls+=("$url")
      done
    fi

    # Append any URLs provided as arguments
    urls+=("$@")

    # Check if any URLs were provided
    if [ "${#urls[@]}" -eq 0 ]; then
      echo "Usage: open-chrome-tabs [-n] <url1> <url2> ... <urlN>"
      echo "Or provide URLs via standard input, each on a new line."
      return 1
    fi

    # Determine Chrome launch options
    if $incognito; then
      open -na "Google Chrome" --args --incognito "${urls[@]}"
    else
      open -na "Google Chrome" --args "${urls[@]}"
    fi
  }
fi

