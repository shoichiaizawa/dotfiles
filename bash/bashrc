# Install or upgrade nvm using the official install script
nvm-setup() {
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/master/install.sh | bash
}

# Lazy-load nvm: sourcing nvm.sh on every shell costs ~310ms.
# Instead, export NVM_DIR and PATH for the current Node, then load nvm.sh
# on first use of nvm/node/npm/npx.
if [[ -d "$HOME/.nvm" ]]; then
  export NVM_DIR="$HOME/.nvm"
  export NVM_SYMLINK_CURRENT=true

  # Add current Node to PATH immediately (avoids lazy-load for simple node/npm use)
  [[ -d "$NVM_DIR/current/bin" ]] && PATH="$NVM_DIR/current/bin:$PATH"

  _nvm_lazy_load() {
    unset -f nvm node npm npx
    [[ -s "$NVM_DIR/nvm.sh" ]] && \. "$NVM_DIR/nvm.sh"
    [[ -r "$NVM_DIR/bash_completion" ]] && \. "$NVM_DIR/bash_completion"
  }
  nvm()  { _nvm_lazy_load; nvm  "$@"; }
  node() { _nvm_lazy_load; node "$@"; }
  npm()  { _nvm_lazy_load; npm  "$@"; }
  npx()  { _nvm_lazy_load; npx  "$@"; }

# Case 2: nvm installed via Homebrew (unsupported by nvm developers)
elif [[ -s "$BREW_PREFIX/opt/nvm/nvm.sh" ]]; then
  export NVM_DIR="$HOME/.nvm"
  [[ ! -d "$NVM_DIR" ]] && mkdir "$NVM_DIR"
  \. "$BREW_PREFIX/opt/nvm/nvm.sh"
  echo -e "\033[0;33mWarning:\033[0m nvm is installed via Homebrew (unsupported)."
  echo "Consider migrating: curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/master/install.sh | bash"
fi

