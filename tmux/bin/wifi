#!/usr/bin/env bash
#
# @(#) wifi v0.3.0 2026-03-01
#
# description:
#   Show WiFi SSID, bandwidth, and signal strength for the tmux status bar.
#   SSID is queried via networksetup on each call (fast). Signal and transmit
#   rate are queried via system_profiler and cached for CACHE_TTL seconds
#   to avoid the ~2s overhead on every status-bar refresh.
#
# output example: "MyNetwork 573Mbs ▂▅  "
#
# usage (tmux.conf):
#   set -g status-right '#(~/.tmux/bin/wifi)'

CACHE_FILE="/tmp/.tmux_wifi_${UID:-0}"
CACHE_TTL=30

signals=(▂ ▅ ▇)

# --- Signal, rate, and connection status via system_profiler (slow — cached) ---
now=$(date +%s)
cache_time=0
rssi=""
rate=""
status=""

if [[ -f "$CACHE_FILE" ]]; then
    read -r cache_time rssi rate status < "$CACHE_FILE"
fi

if [[ -z "$rssi" ]] || (( now - cache_time >= CACHE_TTL )); then
    sp=$(system_profiler SPAirPortDataType 2>/dev/null)
    rssi=$(awk '/Signal \/ Noise/{ match($0, /-[0-9]+/); print substr($0, RSTART, RLENGTH); exit }' <<< "$sp")
    rate=$(awk '/Transmit Rate:/{ print $NF; exit }' <<< "$sp")
    status=$(awk '/Status:/{print $NF; exit}' <<< "$sp")
    rssi="${rssi:--100}"
    rate="${rate:-0}"
    printf '%s %s %s %s\n' "$now" "$rssi" "$rate" "${status:-disconnected}" > "$CACHE_FILE"
fi

if [[ "$status" != "Connected" ]]; then
    echo "offline"
    exit 0
fi

if [[ "$rate" == "0" ]]; then
    echo "no_wifi"
    exit 0
fi

# --- SSID via networksetup (fast; may be unavailable without Location Services) ---
ssid_raw=$(networksetup -getairportnetwork en0 2>/dev/null)
ssid="${ssid_raw#Current Wi-Fi Network: }"
if [[ "$ssid" == "$ssid_raw" || -z "$ssid" ]]; then
    ssid="wifi"  # fallback when Location Services not granted
fi

# --- Signal bar indicator ---
# rssi reference: -50 excellent  -80 not good  -100 bad
signal=""
for ((j = 0; j < "${#signals[@]}"; j++)); do
    if  (( j == 0 && rssi > -100 )) ||
        (( j == 1 && rssi > -80  )) ||
        (( j == 2 && rssi > -50  )); then
        signal="${signal}${signals[$j]}"
    else
        signal="${signal}  "
    fi
done

echo "${ssid} ${rate}Mbs ${signal}"
