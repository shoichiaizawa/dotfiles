{
  "cleanupPeriodDays": 365,
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(basename *)",
      "Bash(brew --prefix*)",
      "Bash(brew config)",
      "Bash(brew info *)",
      "Bash(brew list*)",
      "Bash(brew search *)",
      "Bash(cat *)",
      "Bash(command -v *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(df *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(git blame *)",
      "Bash(git branch*)",
      "Bash(git config --get *)",
      "Bash(git describe*)",
      "Bash(git diff*)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git ls-files*)",
      "Bash(git remote*)",
      "Bash(git rev-parse *)",
      "Bash(git shortlog*)",
      "Bash(git show *)",
      "Bash(git stash list*)",
      "Bash(git status*)",
      "Bash(git tag*)",
      "Bash(head *)",
      "Bash(hostname)",
      "Bash(id)",
      "Bash(ls *)",
      "Bash(man *)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(ps)",
      "Bash(ps *)",
      "Bash(pwd)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(stat *)",
      "Bash(sw_vers*)",
      "Bash(tail *)",
      "Bash(tree *)",
      "Bash(type *)",
      "Bash(uname)",
      "Bash(uname *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(whoami)"
    ],
    "deny": [
      "Bash(chmod -R 777 *)",
      "Bash(dd *)",
      "Bash(diskutil eraseDisk *)",
      "Bash(diskutil partitionDisk *)",
      "Bash(git branch -D *)",
      "Bash(git clean -f*)",
      "Bash(git push --force*)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git push * --force*)",
      "Bash(git push * -f)",
      "Bash(git push * -f *)",
      "Bash(git reset --hard*)",
      "Bash(launchctl *)",
      "Bash(mkfs *)",
      "Bash(reboot*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(shutdown*)",
      "Bash(sudo *)"
    ]
  }
}
